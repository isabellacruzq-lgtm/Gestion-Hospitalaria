<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            prefWidth="1400"
            prefHeight="900"
            stylesheets="@../styles/style.css">

    <!-- SIDEBAR -->

    <left>

        <VBox spacing="20"
              prefWidth="90"
              styleClass="sidebar">

            <Button text="🏠"
                    styleClass="menu-button"/>

            <Button text="📅"
                    styleClass="menu-button"/>

            <Button text="👨‍⚕️"
                    styleClass="menu-button"/>

            <Button text="📋"
                    styleClass="menu-button"/>

        </VBox>

    </left>

    <!-- MAIN -->

    <center>

        <VBox spacing="25"
              style="-fx-padding: 40;">

            <Label text="AGENDAR NUEVA CITA"
                   styleClass="title"/>

            <HBox spacing="20">

                <VBox spacing="10">

                    <Label text="Ciudad"/>
                    <ComboBox prefWidth="300"/>

                </VBox>

                <VBox spacing="10">

                    <Label text="Hospital"/>
                    <ComboBox prefWidth="300"/>

                </VBox>

            </HBox>

            <HBox spacing="20">

                <VBox spacing="10">

                    <Label text="Especialidad"/>
                    <ComboBox prefWidth="300"/>

                </VBox>

                <VBox spacing="10">

                    <Label text="Especialista"/>
                    <ComboBox prefWidth="300"/>

                </VBox>

            </HBox>

            <HBox spacing="20">

                <VBox spacing="10">

                    <Label text="Fecha"/>
                    <DatePicker prefWidth="300"/>

                </VBox>

                <VBox spacing="10">

                    <Label text="Hora"/>
                    <ComboBox prefWidth="300"/>

                </VBox>

            </HBox>

            <VBox spacing="10">

                <Label text="Motivo de consulta"/>
                <TextArea prefWidth="620"
                          prefHeight="150"/>

            </VBox>

            <Button text="CONFIRMAR CITA"
                    styleClass="primary-button"/>

        </VBox>

    </center>

</BorderPane>